{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Provider Gateway",
  "version": "0.2.2",
  "identifier": "com.ccprovidergtw.desktop",
  "build": {
    "beforeDevCommand": "npm run prepare-sidecar -w @claude-code-provider-gateway/desktop && npm run dev -w @claude-code-provider-gateway/panel",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build -w @claude-code-provider-gateway/panel && npm run prepare-sidecar -w @claude-code-provider-gateway/desktop",
    "frontendDist": "../../daemon/dist/static"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code Provider Gateway",
        "width": 1600,
        "height": 930,
        "minWidth": 900,
        "minHeight": 630,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/claude-code-provider-gateway-daemon"
    ]
  },
  "plugins": {}
}
