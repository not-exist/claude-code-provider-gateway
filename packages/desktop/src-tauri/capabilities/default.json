{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window: invoke daemon commands and spawn the sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "process:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/claude-code-provider-gateway-daemon",
          "sidecar": true
        }
      ]
    }
  ]
}
