{
  "name": "@claude-code-provider-gateway/daemon",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/runtime/process.ts src/config/index.ts src/config/schema.ts --format esm --dts --out-dir dist",
    "dev": "tsup src/index.ts src/runtime/process.ts src/config/index.ts src/config/schema.ts --format esm --watch --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts' -type f | sort)",
    "compile": "bun build --compile --target=bun src/index.ts --outfile dist-bin/claude-code-provider-gateway-daemon",
    "compile:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist-bin/claude-code-provider-gateway-daemon-linux-x64",
    "compile:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist-bin/claude-code-provider-gateway-daemon-linux-arm64",
    "compile:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist-bin/claude-code-provider-gateway-daemon-darwin-x64",
    "compile:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist-bin/claude-code-provider-gateway-daemon-darwin-arm64",
    "compile:win-x64": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist-bin/claude-code-provider-gateway-daemon-win-x64.exe",
    "compile:all": "npm run compile:linux-x64 && npm run compile:linux-arm64 && npm run compile:darwin-x64 && npm run compile:darwin-arm64 && npm run compile:win-x64"
  },
  "dependencies": {
    "hono": "^4.7.10",
    "@hono/node-server": "^1.14.3",
    "js-tiktoken": "^1.0.16",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.17"
  }
}
